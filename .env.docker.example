# Subscriptions to monitor - comma-separated list of UUIDs
# This is only used for first-run bootstrap; after that the DB is the source of truth.
AZSCOUT_SUBSCRIPTIONS=

# Scan cadence
AZSCOUT_SCAN_INTERVAL_HOURS=6
AZSCOUT_COST_WINDOW_DAYS=30
AZSCOUT_METRIC_WINDOW_DAYS=14
AZSCOUT_CPU_THRESHOLD=5.0

# Inventory cap
AZSCOUT_INVENTORY_LIMIT=5000

# Logging
AZSCOUT_LOG_LEVEL=INFO

# Azure auth - leave blank if mounting .azure into the container
# AZURE_TENANT_ID=
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=
